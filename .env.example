# ── Models ────────────────────────────────────────────────────────────────────
# Absolute path to your models directory (mounted into api and batch containers)
VZ_MODELS_DIR=/path/to/your/models

# ── OIDC / oauth2-proxy ───────────────────────────────────────────────────────
# Identity provider OIDC discovery URL:
#   Google:   https://accounts.google.com
#   Entra ID: https://login.microsoftonline.com/{tenant-id}/v2.0
#   Okta:     https://{domain}.okta.com
OIDC_ISSUER_URL=https://accounts.google.com

# OAuth2 client credentials — register an app with your identity provider
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# 32-byte random secret for session cookies.  Generate with:
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
OAUTH2_COOKIE_SECRET=

# Restrict login to a specific email domain (e.g. "example.com").
# Leave as "*" to allow any authenticated email.
ALLOWED_EMAIL_DOMAINS=*

# Set to "true" when serving over HTTPS (required in production)
OAUTH2_COOKIE_SECURE=false

# ── Deployment ────────────────────────────────────────────────────────────────
# Hostname used for the OIDC redirect URL and CORS origin
HOST=localhost

# Port Traefik listens on (default 80)
HTTP_PORT=80

# ── Batch service ─────────────────────────────────────────────────────────────
# Number of concurrent extraction workers in the batch service
BATCH_WORKERS=4

# Shared secret between the API and batch service.  Generate with:
#   make gen-batch-secret
# When set, the batch service rejects requests that don't carry this value in
# the X-Batch-Secret header.  Leave unset for local dev (no containers).
BATCH_SERVICE_SECRET=

# ── Observability ─────────────────────────────────────────────────────────────
# Log level for the API and batch services (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# OTLP/HTTP endpoint for distributed tracing.  Leave unset to disable tracing.
# With Jaeger (make up-otel):     OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# With Grafana Tempo:             OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
# With Honeycomb:                 OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Access control ────────────────────────────────────────────────────────────
# Comma-separated emails / domain wildcards for system administrators.
# System admins have full platform access (all models, all config).
# Supports exact email, domain wildcard (*@example.com), or * for everyone.
# DEV_USER is always treated as a system admin in local development.
VZ_SYSTEM_ADMINS=

# Creators can publish vizgrams and use the query/view builder.
# System admins implicitly satisfy Creator. Same pattern format as VZ_SYSTEM_ADMINS.
# Use * to allow any authenticated user to publish (open platform).
VZ_CREATORS=

# ── Caption generation (vizgrams) ────────────────────────────────────────────
# LLM provider for auto-generating vizgram captions on publish.
# Options: openai (default) | anthropic | bedrock | ollama | none
VZ_CAPTION_PROVIDER=openai

# OpenAI — get a key at platform.openai.com
OPENAI_API_KEY=

# Anthropic — get a key at console.anthropic.com
# ANTHROPIC_API_KEY=

# AWS Bedrock — uses ambient AWS credentials (IAM role or ~/.aws/credentials)
# AWS_REGION=us-east-1

# Ollama — local LLM, no API key required
# OLLAMA_BASE_URL=http://localhost:11434

# Override the model used by any provider (optional — each provider has a sensible default)
# VZ_CAPTION_MODEL=gpt-4o

# ── Auth provider ─────────────────────────────────────────────────────────────
# Identifies which OAuth provider is in use — stored alongside each user record.
# Options: dex (default) | github | entra | dev
# VZ_AUTH_PROVIDER=dex

# ── Feed ranking ──────────────────────────────────────────────────────────────
# Hours after which a vizgram's score halves due to age (default: 72 = 3 days)
# VZ_FEED_FRESHNESS_HALFLIFE_HOURS=72
# Diversity penalty multiplier per repeated dataset in the feed (default: 0.5)
# VZ_FEED_DIVERSITY_PENALTY=0.5

# ── Local development (no docker-compose) ────────────────────────────────────
# Set this to bypass the auth proxy when running services directly.
# NEVER set this in a deployed environment.
# DEV_USER=you@example.com
