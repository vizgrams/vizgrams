<clickhouse>
    <!-- Listen wildcard address to allow accepting connections from other containers and host network. -->
    <listen_host>::</listen_host>
    <listen_host>0.0.0.0</listen_host>
    <listen_try>1</listen_try>

    <!-- Memory: limit to 65% of RAM to leave room for API, batch, and OS on small instances.
         Default is 90% which leaves nothing for other containers on 4GB instances. -->
    <max_server_memory_usage_to_ram_ratio>0.65</max_server_memory_usage_to_ram_ratio>

    <!-- System log retention: keep small to avoid memory pressure on constrained instances.
         Default TTL is unlimited which can consume hundreds of MB. -->
    <query_log>
        <database>system</database>
        <table>query_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <ttl>event_date + INTERVAL 3 DAY</ttl>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
    </query_log>
    <trace_log>
        <database>system</database>
        <table>trace_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <ttl>event_date + INTERVAL 1 DAY</ttl>
    </trace_log>
    <text_log>
        <database>system</database>
        <table>text_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <ttl>event_date + INTERVAL 1 DAY</ttl>
    </text_log>
    <metric_log>
        <database>system</database>
        <table>metric_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <ttl>event_date + INTERVAL 1 DAY</ttl>
    </metric_log>
    <asynchronous_metric_log>
        <database>system</database>
        <table>asynchronous_metric_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <ttl>event_date + INTERVAL 1 DAY</ttl>
    </asynchronous_metric_log>
</clickhouse>
